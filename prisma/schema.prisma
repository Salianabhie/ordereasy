generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Restaurant {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  password    String?
  description String?
  logoUrl     String?
  coverUrl    String?
  address     String?
  phone       String?
  currency    String   @default("USD")
  taxRate     Float    @default(0.08)
  plan        String   @default("pro")
  latitude    Float?
  longitude   Float?
  locationRadius Float  @default(100) // meters
  defaultLanguage String @default("en")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  categories Category[]
  menuItems  MenuItem[]
  tables     Table[]
  orders     Order[]
  reservations Reservation[]
  waitlist   Waitlist[]
  promotions Promotion[]
}

model Table {
  id           String         @id @default(cuid())
  number       Int
  qrCode       String         @unique
  capacity     Int            @default(4)
  status       String         @default("available")
  restaurantId String
  restaurant   Restaurant     @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  reservations Reservation[]

  orders Order[]

  @@unique([restaurantId, number])
}

model Reservation {
  id           String     @id @default(cuid())
  customerName String
  customerPhone String
  customerEmail String?
  partySize    Int
  date         DateTime
  time         String
  status       String     @default("confirmed")
  specialRequests String?
  restaurantId String
  tableId      String?
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  table        Table?     @relation(fields: [tableId], references: [id])
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model Waitlist {
  id           String     @id @default(cuid())
  customerName String
  customerPhone String
  partySize    Int
  status       String     @default("waiting")
  estimatedTime Int?
  position     Int
  notified     Boolean    @default(false)
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model Customer {
  id           String   @id @default(cuid())
  phone        String   @unique
  name         String?
  email        String?
  language     String   @default("en")
  loyaltyPoints Int     @default(0)
  totalOrders  Int      @default(0)
  totalSpent   Float    @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  orders       Order[]
}

model Promotion {
  id           String   @id @default(cuid())
  name         String
  type         String   // "happy_hour", "discount", "special"
  discountPercent Float?
  startTime    String   // HH:MM format
  endTime      String   // HH:MM format
  daysOfWeek   String   // Comma-separated: "1,2,3,4,5" for weekdays
  menuItemIds  String   // Comma-separated IDs of affected items
  isActive     Boolean  @default(true)
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}


model Category {
  id           String     @id @default(cuid())
  name         String
  slug         String
  description  String?
  imageUrl     String?
  sortOrder    Int        @default(0)
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  menuItems    MenuItem[]

  @@unique([restaurantId, slug])
}

model MenuItem {
  id           String   @id @default(cuid())
  name         String
  description  String?
  price        Float
  imageUrl     String?
  isAvailable  Boolean  @default(true)
  isPopular    Boolean  @default(false)
  isTodaySpecial Boolean @default(false)
  prepTime     Int      @default(15)
  sortOrder    Int      @default(0)
  tags         String   @default("")
  categoryId   String
  restaurantId String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  category            Category             @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  restaurant          Restaurant           @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  customizationGroups CustomizationGroup[]
  orderItems          OrderItem[]
  upsellRules         UpsellRule[]         @relation("TriggerItem")
  upsellTargets       UpsellRule[]         @relation("SuggestedItem")
}

model CustomizationGroup {
  id         String              @id @default(cuid())
  name       String
  required   Boolean             @default(false)
  maxSelect  Int                 @default(1)
  menuItemId String
  menuItem   MenuItem            @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  options    CustomizationOption[]
}

model CustomizationOption {
  id      String             @id @default(cuid())
  name    String
  price   Float              @default(0)
  groupId String
  group   CustomizationGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
}

model Order {
  id           String     @id @default(cuid())
  orderNumber  Int
  status       String     @default("pending")
  subtotal     Float
  tax          Float
  total        Float
  notes        String?
  paymentStatus String    @default("unpaid")
  restaurantId String
  tableId      String?
  customerId   String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  table      Table?     @relation(fields: [tableId], references: [id])
  customer   Customer?  @relation(fields: [customerId], references: [id])
  items      OrderItem[]
}

model OrderItem {
  id             String @id @default(cuid())
  quantity       Int
  unitPrice      Float
  customizations String @default("[]")
  notes          String?
  orderId        String
  menuItemId     String

  order    Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItem MenuItem @relation(fields: [menuItemId], references: [id])
}

model UpsellRule {
  id              String   @id @default(cuid())
  triggerItemId   String
  suggestedItemId String
  message         String
  discount        Float    @default(0)

  triggerItem   MenuItem @relation("TriggerItem", fields: [triggerItemId], references: [id], onDelete: Cascade)
  suggestedItem MenuItem @relation("SuggestedItem", fields: [suggestedItemId], references: [id], onDelete: Cascade)

  @@unique([triggerItemId, suggestedItemId])
}
